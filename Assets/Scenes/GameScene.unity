  m_Script: {fileID: 11500000, guid: 1411981de240349349e528e7969edf99, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  puzzleName: Binary Decode
  puzzleDescription: Walls show bits and the decoding path; the terminal speaks in
    riddles.
  maxAttempts: 5
  OnPuzzleSolved:
    m_PersistentCalls:
      m_Calls: []
  OnPuzzleFailed:
    m_PersistentCalls:
      m_Calls: []
  OnFeedback:
    m_PersistentCalls:
      m_Calls: []
  plainText: CODE
  terminalRiddle: "On one wall, I speak in only two voices:\n0 and 1, again and again.\nBut
    I am not numbers forever.\nLook to the other wall \u2014\nFirst count me into
    numbers,\nThen find my place in the grand alphabet table.\nFollow the path from
    the wall!\nOnly then will my true message appear."

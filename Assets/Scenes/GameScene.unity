  m_Script: {fileID: 11500000, guid: d13444dca11484ee1b398d22b89f3b89, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  puzzleName: IP <-> Binary
  puzzleDescription: Walls show Part 1 (IPv4) and Part 2 (binary); the terminal explains
    each step.
  maxAttempts: 5
  OnPuzzleSolved:
    m_PersistentCalls:
      m_Calls: []
  OnPuzzleFailed:
    m_PersistentCalls:
      m_Calls: []
  OnFeedback:
    m_PersistentCalls:
      m_Calls: []
  part1Ip: 10.20.30.40
  part2Ip: 172.16.254.1
  part1Riddle: 'On the left wall,

    four numbers mark an address.

    Break them
    apart,

    turn each into 8 bits,

    and the hidden code will be complete.'
  part2Riddle: 'On the right wall,

    I am written in four groups of bits.

    Read
    each group as a number,

    place the dots between them,

    and the address
    will show itself.'
